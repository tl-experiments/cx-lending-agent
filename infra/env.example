# Copy to infra/.env and fill in your values. Never commit the real .env.
# Read by agent/ces_common.py (the SCRAPI provisioner) and the infra scripts.

# --- GCP ---
PROJECT_ID=your-project-id
PROJECT_NUMBER=000000000000
CES_LOCATION=us                       # Gemini Enterprise for CX (CES) app location

# --- Backend (mock lending API + chat proxy on Cloud Run) ---
# LOCAL-DEV PLACEHOLDER ONLY — not the production secret. The deployed backend reads its key
# from Secret Manager (mounted as BACKEND_API_KEY on Cloud Run); that value is rotated and
# never committed. This default only matters when running the mock API locally.
BACKEND_API_KEY=demo-key-gcex
BACKEND_URL=http://localhost:8080     # becomes the Cloud Run URL once deployed
CLOUD_RUN_SERVICE=tilicho-credit-api

# --- Grounding (Vertex AI RAG Engine) ---
# Run infra/setup-ragengine.sh to create the corpus + import docs from the bucket; it prints
# the corpus name to paste here. The agent grounds via a CES fileSearchTool over this corpus.
DATA_BUCKET=gs://your-project-id-grounding
RAG_CORPUS=projects/000000000000/locations/us-central1/ragCorpora/REPLACE_ME
